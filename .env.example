# Server
PORT=4141
HOST=0.0.0.0

# Claude CLI
CLAUDE_BINARY=claude
CLAUDE_MODEL=
CLAUDE_MAX_TURNS=1

# Startup mode: "bare" (fastest, needs CLAUDE_CODE_OAUTH_TOKEN), "lean" (--setting-sources), "full" (loads everything)
CLAUDE_MODE=bare

# Required for bare mode — OAuth token from Claude Code CLI
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: path or JSON for --settings (e.g. apiKeyHelper)
CLAUDE_SETTINGS=

# For lean mode: which setting sources to load (user, project, local)
CLAUDE_SETTING_SOURCES=user

# Router auth (comma-separated API keys; empty = no auth)
API_KEYS=
