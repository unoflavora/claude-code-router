# Server
PORT=4141
HOST=0.0.0.0

# Claude CLI
CLAUDE_BINARY=claude
CLAUDE_MODEL=
CLAUDE_MAX_TURNS=20

# Startup mode:
#   "lean" — --setting-sources; recommended (supports CLAUDE_CODE_OAUTH_TOKEN)
#   "full" — loads everything
CLAUDE_MODE=lean

# OAuth token from Claude Code CLI
CLAUDE_CODE_OAUTH_TOKEN=

# Optional: path or JSON for --settings (e.g. apiKeyHelper)
CLAUDE_SETTINGS=

# For lean mode: which setting sources to load (user, project, local)
CLAUDE_SETTING_SOURCES=user

# Router auth (comma-separated API keys; empty = no auth)
API_KEYS=

# MCP: path (inside container) or inline JSON for --mcp-config
MCP_CONFIG=
# "1" to pass --strict-mcp-config (only use servers from MCP_CONFIG)
MCP_STRICT=
# Comma/space-separated tool allowlist (e.g. "mcp__dbportal__list_connections Bash")
ALLOWED_TOOLS=
# Comma/space-separated tool denylist. Default: "ToolSearch" (avoids the tool-discovery
# indirection so MCP tools are used directly). Set to "" to allow all.
DISALLOWED_TOOLS=
# Permission mode: acceptEdits | auto | bypassPermissions | default | dontAsk | plan
PERMISSION_MODE=
# Appended to Claude Code's built-in system prompt. Default: acknowledge user before tool calls.
# Set to any other text to customize. Leave unset to use default.
CLAUDE_APPEND_SYSTEM_PROMPT=
# SSE heartbeat interval (ms) during streaming. 0 = disabled.
SSE_HEARTBEAT_MS=
# Set to 0 when MCP endpoint uses a self-signed cert
NODE_TLS_REJECT_UNAUTHORIZED=
